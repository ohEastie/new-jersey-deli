---
const {
	title = 'New Jersey Grocery & Deli',
	description = 'Family-owned New Jersey Grocery & Deli serving Oakland Park and Margate, Florida since 1994.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logo.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--blue: #005bbb;
		--blue-deep: #073763;
		--blue-soft: #eaf4ff;
		--gold: #f5b82e;
		--gold-deep: #c98611;
		--neutral: #f7f5ef;
		--neutral-strong: #eee8d8;
		--ink: #17202a;
		--ink-soft: #4f5963;
		--white: #fffdf8;
		--shadow: 0 22px 70px rgba(7, 55, 99, 0.14);
		--shadow-soft: 0 14px 38px rgba(7, 55, 99, 0.1);
		--radius: 8px;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		color: var(--ink);
		background: var(--white);
		scroll-behavior: smooth;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-width: 320px;
	}

	body {
		background:
			linear-gradient(180deg, rgba(234, 244, 255, 0.8), rgba(255, 253, 248, 1) 38rem),
			var(--white);
		line-height: 1.6;
	}

	body.no-scroll {
		overflow: hidden;
	}

	img {
		display: block;
		max-width: 100%;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	button,
	input,
	textarea {
		font: inherit;
	}

	.section {
		padding: 4.5rem 1rem;
		scroll-margin-top: 5.25rem;
	}

	.section--cream {
		background: var(--neutral);
	}

	.section--white {
		background: var(--white);
	}

	.section--charcoal {
		background:
			linear-gradient(135deg, rgba(0, 91, 187, 0.16), rgba(245, 184, 46, 0.08)),
			var(--blue-deep);
		color: var(--white);
	}

	.container {
		width: min(1120px, 100%);
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--blue);
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.section--charcoal .eyebrow {
		color: var(--gold);
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.04;
		letter-spacing: 0;
	}

	h1 {
		max-width: 11ch;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(3rem, 12vw, 6.55rem);
	}

	h2 {
		max-width: 780px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(2rem, 7vw, 4.05rem);
	}

	h3 {
		font-size: 1.22rem;
	}

	.lead {
		color: var(--ink-soft);
		font-size: clamp(1.05rem, 4vw, 1.25rem);
	}

	.section--charcoal .lead {
		color: rgba(255, 253, 247, 0.78);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.82rem 1.08rem;
		border: 1px solid transparent;
		border-radius: var(--radius);
		font-weight: 800;
		line-height: 1.1;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease,
			border-color 180ms ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn--primary {
		background: var(--gold);
		color: var(--blue-deep);
		box-shadow: 0 14px 32px rgba(245, 184, 46, 0.25);
	}

	.btn--primary:hover {
		background: #ffd063;
	}

	.btn--secondary {
		background: rgba(255, 253, 247, 0.92);
		border-color: rgba(7, 55, 99, 0.18);
		color: var(--blue-deep);
	}

	.btn--secondary:hover {
		border-color: rgba(0, 91, 187, 0.34);
		background: var(--white);
	}

	[data-i18n] {
		transition: opacity 140ms ease;
	}

	.is-translating [data-i18n] {
		opacity: 0.34;
	}

	@media (min-width: 760px) {
		.section {
			padding: 6.5rem 1.5rem;
		}
	}
</style>
