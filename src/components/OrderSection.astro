---
const orderLinks = [
	{
		key: 'uber',
		label: 'Uber Eats',
		href: 'https://www.order.store/store/new-jersey-deli-2/RdKfeHo8V3C5XNzBEly_wg?from_challenge=1',
		logo: '/images/Uber-Eats-Logo.png',
	},
	{
		key: 'doordash',
		label: 'DoorDash',
		href: 'https://order.online/store/303113?pickup=true&redirected=true',
		logo: '/images/DoorDash-logo.png',
	},
];
---

<section class="section order-section" id="order" aria-labelledby="order-title">
	<div class="container order-strip__inner">
		<div class="order-strip__copy">
			<p class="eyebrow" data-i18n="order.eyebrow">Order online</p>
			<h2 id="order-title" data-i18n="order.title">Bring the deli counter home.</h2>
			<p data-i18n="order.copy">
				Choose your delivery app for sandwiches, breakfast, and neighborhood deli favorites.
			</p>
		</div>

		<div class="order-strip__actions" aria-label="Online ordering options">
			{orderLinks.map((link) => (
				<a class={`order-link order-link--${link.key}`} href={link.href} target="_blank" rel="noreferrer">
					<div class="order-link__body">
						<span>
							<img class="order-link__logo" src={link.logo} alt={link.label} loading="lazy" />
							<small data-i18n={`order.${link.key}Copy`}>
								{link.key === 'uber' ? 'Delivery through Uber Eats' : 'Pickup and delivery through DoorDash'}
							</small>
						</span>
						<em data-i18n="order.action">Order now</em>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.order-section {
		position: relative;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(245, 184, 46, 0.14), rgba(255, 253, 248, 0.02)),
			var(--blue-deep);
		color: var(--white);
	}

	.order-strip__inner {
		display: grid;
		gap: 1.5rem;
		align-items: center;
	}

	.order-strip__copy h2 {
		max-width: 520px;
		margin-bottom: 0.45rem;
		font-size: clamp(1.8rem, 6vw, 3rem);
	}

	.order-strip__copy p:last-child {
		max-width: 560px;
		margin-bottom: 0;
		color: rgba(255, 253, 248, 0.78);
		font-weight: 650;
	}

	.order-strip__actions {
		display: grid;
		gap: 1rem;
	}

	.order-link {
		display: grid;
		grid-template-rows: 1fr;
		gap: 0;
		overflow: hidden;
		min-height: 100%;
		padding: 0;
		border: 1px solid rgba(255, 253, 248, 0.2);
		border-radius: var(--radius);
		background: rgba(255, 253, 248, 0.08);
		transition:
			transform 180ms ease,
			background 180ms ease,
			border-color 180ms ease;
	}

	.order-link:hover {
		transform: translateY(-3px);
		border-color: rgba(245, 184, 46, 0.62);
		background: rgba(255, 253, 248, 0.13);
	}

	.order-link__body {
		display: grid;
		grid-template-rows: 1fr auto;
		gap: 1.85rem;
		min-height: 18rem;
		padding: 2rem 1.35rem 1.45rem;
	}

	.order-link span {
		display: grid;
		justify-items: center;
		gap: 1.25rem;
		align-content: center;
		min-width: 0;
		text-align: center;
	}

	.order-link__logo {
		width: min(21rem, 92%);
		max-width: 21rem;
		height: 5.25rem;
		aspect-ratio: auto;
		border-radius: 0;
		object-fit: contain;
		object-position: center;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.14));
	}

	.order-link small {
		color: rgba(255, 253, 248, 0.76);
		font-size: 0.86rem;
		font-weight: 750;
		line-height: 1.25;
	}

	.order-link em {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		justify-self: center;
		width: min(100%, 13rem);
		min-height: 3.15rem;
		padding-inline: 1.65rem;
		border-radius: 6px;
		background: var(--gold);
		color: var(--blue-deep);
		font-size: 0.86rem;
		font-style: normal;
		font-weight: 950;
		text-align: center;
		text-transform: uppercase;
	}

	@media (min-width: 760px) {
		.order-strip__inner {
			grid-template-columns: minmax(0, 1fr) minmax(360px, 0.68fr);
			gap: 2rem;
		}

		.order-strip__actions {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.order-link__body {
			min-height: 20rem;
			padding: 2.35rem 1.5rem 1.55rem;
		}
	}
</style>
