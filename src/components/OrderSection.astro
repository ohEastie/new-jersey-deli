---
const orderLinks = [
	{
		key: 'uber',
		label: 'Uber Eats',
		href: 'https://www.order.store/store/new-jersey-deli-2/RdKfeHo8V3C5XNzBEly_wg?from_challenge=1',
		image: '/images/FEATUREDSANDcuban.avif',
	},
	{
		key: 'doordash',
		label: 'DoorDash',
		href: 'https://order.online/store/303113?pickup=true&redirected=true',
		image: '/images/BREAKFAST2eggsnbacon.avif',
	},
];
---

<section class="section order-section" id="order" aria-labelledby="order-title">
	<div class="container order-strip__inner">
		<div class="order-strip__copy">
			<p class="eyebrow" data-i18n="order.eyebrow">Order online</p>
			<h2 id="order-title" data-i18n="order.title">Bring the deli counter home.</h2>
			<p data-i18n="order.copy">
				Choose your delivery app for sandwiches, breakfast, and neighborhood deli favorites.
			</p>
		</div>

		<div class="order-strip__actions" aria-label="Online ordering options">
			{orderLinks.map((link) => (
				<a class={`order-link order-link--${link.key}`} href={link.href} target="_blank" rel="noreferrer">
					<img src={link.image} alt="" loading="lazy" />
					<span>
						<strong data-i18n={`order.${link.key}`}>{link.label}</strong>
						<small data-i18n={`order.${link.key}Copy`}>
							{link.key === 'uber' ? 'Delivery through Uber Eats' : 'Pickup and delivery through DoorDash'}
						</small>
					</span>
					<em data-i18n="order.action">Order now</em>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.order-section {
		position: relative;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(245, 184, 46, 0.14), rgba(255, 253, 248, 0.02)),
			var(--blue-deep);
		color: var(--white);
	}

	.order-strip__inner {
		display: grid;
		gap: 1.5rem;
		align-items: center;
	}

	.order-strip__copy h2 {
		max-width: 520px;
		margin-bottom: 0.45rem;
		font-size: clamp(1.8rem, 6vw, 3rem);
	}

	.order-strip__copy p:last-child {
		max-width: 560px;
		margin-bottom: 0;
		color: rgba(255, 253, 248, 0.78);
		font-weight: 650;
	}

	.order-strip__actions {
		display: grid;
		gap: 0.75rem;
	}

	.order-link {
		display: grid;
		grid-template-columns: 5.25rem minmax(0, 1fr);
		gap: 0.9rem;
		align-items: center;
		min-height: 6.4rem;
		padding: 0.65rem;
		border: 1px solid rgba(255, 253, 248, 0.2);
		border-radius: var(--radius);
		background: rgba(255, 253, 248, 0.08);
		transition:
			transform 180ms ease,
			background 180ms ease,
			border-color 180ms ease;
	}

	.order-link:hover {
		transform: translateY(-3px);
		border-color: rgba(245, 184, 46, 0.62);
		background: rgba(255, 253, 248, 0.13);
	}

	.order-link img {
		width: 100%;
		aspect-ratio: 1;
		border-radius: 6px;
		object-fit: cover;
		object-position: center;
	}

	.order-link span {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.order-link strong {
		color: var(--gold);
		font-size: 1.15rem;
		font-weight: 950;
	}

	.order-link small {
		color: rgba(255, 253, 248, 0.76);
		font-size: 0.86rem;
		font-weight: 750;
		line-height: 1.25;
	}

	.order-link em {
		grid-column: 1 / -1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.65rem;
		border-radius: 6px;
		background: var(--gold);
		color: var(--blue-deep);
		font-size: 0.86rem;
		font-style: normal;
		font-weight: 950;
		text-transform: uppercase;
	}

	@media (min-width: 760px) {
		.order-strip__inner {
			grid-template-columns: minmax(0, 1fr) minmax(360px, 0.68fr);
			gap: 2rem;
		}

		.order-strip__actions {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.order-link {
			grid-template-columns: 1fr;
			align-content: start;
			min-height: 100%;
			padding: 0.8rem;
		}

		.order-link img {
			aspect-ratio: 4 / 3;
		}
	}
</style>
