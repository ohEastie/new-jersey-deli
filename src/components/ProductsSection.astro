---
const products = [
	{
		key: 'chivito',
		image: '/images/FEATUREDSANDchivito.avif',
		alt: 'Chivito sandwich with fries',
	},
	{
		key: 'cuban',
		image: '/images/FEATUREDSANDcuban.avif',
		alt: 'Pressed Cuban sandwich',
	},
	{
		key: 'breakfast',
		image: '/images/BREAKFASTperico.avif',
		alt: 'Perico breakfast plate',
	},
	{
		key: 'medianoche',
		image: '/images/FEATUREDSANDmedianoche.avif',
		alt: 'Medianoche sandwich',
	},
	{
		key: 'bistec',
		image: '/images/FEATUREDSANDbistec.avif',
		alt: 'Bistec sandwich',
	},
	{
		key: 'porkroll',
		image: '/images/FEATUREDSANDporkroll.avif',
		alt: 'Pork roll sandwich',
	},
];
---

<section class="section section--cream products" id="products">
	<div class="container">
		<div class="products__heading">
			<div>
				<p class="eyebrow" data-i18n="products.eyebrow">Featured favorites</p>
				<h2 data-i18n="products.title">Deli counter comfort with grocery convenience.</h2>
			</div>
			<p class="lead" data-i18n="products.copy">
				Real deli favorites, photographed close and kept simple: Uruguayan sandwiches,
				breakfast plates, Cuban classics, and quick pickup comfort.
			</p>
		</div>

		<div class="products__feature">
			<img src="/images/BREAKFAST2eggsnbaconnfries.avif" alt="Two eggs with bacon and home fries" loading="lazy" />
			<div>
				<p class="eyebrow" data-i18n="products.featureEyebrow">Breakfast to lunch</p>
				<h3 data-i18n="products.featureTitle">The kind of food people build routines around.</h3>
				<p data-i18n="products.featureCopy">
					Start with eggs and coffee, come back for a pressed sandwich, and leave with something
					for home. That is the neighborhood deli rhythm.
				</p>
			</div>
		</div>

		<div class="products__grid" aria-label="Featured menu photography">
			{products.map((product) => (
				<article class="product-card">
					<img src={product.image} alt={product.alt} loading="lazy" />
					<div class="product-card__content">
						<h3 data-i18n={`products.${product.key}.title`}>
							{product.key === 'chivito'
								? 'Chivito'
								: product.key === 'cuban'
									? 'Cuban sandwich'
									: product.key === 'breakfast'
										? 'Breakfast plates'
										: product.key === 'medianoche'
											? 'Medianoche'
											: product.key === 'bistec'
												? 'Bistec'
												: 'Pork roll'}
						</h3>
						<p data-i18n={`products.${product.key}.copy`}>
							{product.key === 'chivito'
								? 'A signature Uruguayan favorite layered for a generous, satisfying lunch.'
								: product.key === 'cuban'
									? 'Pressed, familiar, and made for the kind of stop that becomes routine.'
									: product.key === 'breakfast'
										? 'Warm morning plates for early workdays, family errands, and weekend starts.'
										: product.key === 'medianoche'
											? 'A sweet-savory classic that keeps the deli counter feeling personal.'
											: product.key === 'bistec'
												? 'A hearty steak sandwich with the comfort of a counter-made favorite.'
												: 'A breakfast-and-lunch staple made for quick stops and loyal regulars.'}
						</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.products__heading {
		display: grid;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.products__heading .lead {
		max-width: 520px;
	}

	.products__feature {
		display: grid;
		gap: 1rem;
		margin-bottom: 1rem;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--blue-deep);
		color: var(--white);
		box-shadow: var(--shadow);
	}

	.products__feature img {
		width: 100%;
		aspect-ratio: 16 / 11;
		object-fit: cover;
		object-position: center;
	}

	.products__feature > div {
		padding: 0 1.2rem 1.25rem;
	}

	.products__feature h3 {
		max-width: 620px;
		margin-bottom: 0.65rem;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.75rem, 6vw, 3rem);
		line-height: 1.05;
	}

	.products__feature p:not(.eyebrow) {
		max-width: 590px;
		margin-bottom: 0;
		color: rgba(255, 253, 248, 0.78);
		font-weight: 650;
	}

	.products__grid {
		display: grid;
		gap: 1rem;
	}

	.product-card {
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--white);
		box-shadow: var(--shadow-soft);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.product-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow);
	}

	.product-card img {
		width: 100%;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: center;
	}

	.product-card__content {
		min-height: 164px;
		padding: 1.15rem;
	}

	.product-card h3 {
		margin-bottom: 0.5rem;
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.55rem;
	}

	.product-card p {
		color: var(--ink-soft);
	}

	@media (min-width: 760px) {
		.products__heading {
			grid-template-columns: minmax(0, 1fr) minmax(320px, 0.5fr);
			align-items: end;
			gap: 2rem;
		}

		.products__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 900px) {
		.products__feature {
			grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.72fr);
			align-items: center;
		}

		.products__feature img {
			height: 100%;
			aspect-ratio: auto;
		}

		.products__feature > div {
			padding: 2rem 2rem 2rem 0;
		}
	}

	@media (min-width: 1040px) {
		.products__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
