---
const products = [
	{
		key: 'sandwiches',
		image: 'https://images.unsplash.com/photo-1528735602780-2552fd46c7af?auto=format&fit=crop&w=900&q=82',
	},
	{
		key: 'groceries',
		image: 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=900&q=82',
	},
	{
		key: 'drinks',
		image: 'https://images.unsplash.com/photo-1544145945-f90425340c7e?auto=format&fit=crop&w=900&q=82',
	},
	{
		key: 'sides',
		image: 'https://images.unsplash.com/photo-1625938144755-652e08e359b7?auto=format&fit=crop&w=900&q=82',
	},
];
---

<section class="section section--cream products" id="products">
	<div class="container">
		<div class="products__heading">
			<div>
				<p class="eyebrow" data-i18n="products.eyebrow">Featured favorites</p>
				<h2 data-i18n="products.title">Deli counter comfort with grocery convenience.</h2>
			</div>
			<p class="lead" data-i18n="products.copy">
				Placeholder selections for a menu-ready homepage: fresh sandwiches, breakfast staples,
				pantry goods, snacks, drinks, and family favorites.
			</p>
		</div>

		<div class="products__grid">
			{products.map((product) => (
				<article class="product-card">
					<img src={product.image} alt="" loading="lazy" />
					<div class="product-card__content">
						<h3 data-i18n={`products.${product.key}.title`}>
							{product.key === 'sandwiches'
								? 'Sandwiches'
								: product.key === 'groceries'
									? 'Grocery items'
									: product.key === 'drinks'
										? 'Drinks'
										: 'Sides'}
						</h3>
						<p data-i18n={`products.${product.key}.copy`}>
							{product.key === 'sandwiches'
								? 'Fresh deli favorites made for lunch breaks, family stops, and quick pickup.'
								: product.key === 'groceries'
									? 'Everyday pantry goods, snacks, and essentials for the ride home.'
									: product.key === 'drinks'
										? 'Cold drinks, coffee, and grab-and-go refreshments.'
										: 'Simple sides and deli extras to round out the meal.'}
						</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.products__heading {
		display: grid;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.products__heading .lead {
		max-width: 520px;
	}

	.products__grid {
		display: grid;
		gap: 1rem;
	}

	.product-card {
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--white);
		box-shadow: var(--shadow-soft);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.product-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow);
	}

	.product-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		object-position: center;
	}

	.product-card__content {
		min-height: 164px;
		padding: 1.15rem;
	}

	.product-card h3 {
		margin-bottom: 0.5rem;
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.55rem;
	}

	.product-card p {
		color: var(--ink-soft);
	}

	@media (min-width: 760px) {
		.products__heading {
			grid-template-columns: minmax(0, 1fr) minmax(320px, 0.5fr);
			align-items: end;
			gap: 2rem;
		}

		.products__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1040px) {
		.products__grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}
</style>
