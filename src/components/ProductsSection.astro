---
const breakfastFavorites = [
	{
		key: 'eggsBacon',
		image: '/images/BREAKFAST2eggsnbacon.avif',
		alt: 'Two eggs and bacon breakfast plate',
	},
	{
		key: 'eggsBaconFries',
		image: '/images/BREAKFAST2eggsnbaconnfries.avif',
		alt: 'Two eggs with bacon and home fries',
	},
	{
		key: 'crossHamCheese',
		image: '/images/BREAKFASTcrosshamncheese.avif',
		alt: 'Croissant with ham and cheese',
	},
	{
		key: 'perico',
		image: '/images/BREAKFASTperico.avif',
		alt: 'Perico breakfast plate',
	},
];

const signatureSandwiches = [
	{
		key: 'cuban',
		image: '/images/FEATUREDSANDcuban.avif',
		alt: 'Pressed Cuban sandwich',
	},
	{
		key: 'chivito',
		image: '/images/FEATUREDSANDchivito.avif',
		alt: 'Chivito sandwich with fries',
	},
	{
		key: 'bistec',
		image: '/images/FEATUREDSANDbistec.avif',
		alt: 'Bistec sandwich',
	},
	{
		key: 'porkroll',
		image: '/images/FEATUREDSANDporkroll.avif',
		alt: 'Pork roll sandwich',
	},
	{
		key: 'hamEggCheese',
		image: '/images/FEATUREDSANDhameggncheese.avif',
		alt: 'Ham egg and cheese sandwich',
	},
	{
		key: 'medianoche',
		image: '/images/FEATUREDSANDmedianoche.avif',
		alt: 'Medianoche sandwich',
	},
];

const itemLabels = {
	eggsBacon: '2 Eggs & Bacon',
	eggsBaconFries: '2 Eggs & Bacon with Fries',
	crossHamCheese: 'Cross Ham & Cheese',
	perico: 'Perico',
	cuban: 'Cuban',
	chivito: 'Chivito',
	bistec: 'Bistec',
	porkroll: 'Pork Roll',
	hamEggCheese: 'Ham Egg & Cheese',
	medianoche: 'Medianoche',
};

const itemDescriptions = {
	eggsBacon: 'A classic hot breakfast for early mornings and regular stops.',
	eggsBaconFries: 'A fuller plate with crispy potatoes for a heartier start.',
	crossHamCheese: 'Buttery, warm, and easy to take with coffee on the go.',
	perico: 'A Latin breakfast favorite with bright, familiar comfort.',
	cuban: 'Pressed, familiar, and made for the kind of stop that becomes routine.',
	chivito: 'A signature Uruguayan favorite layered for a generous lunch.',
	bistec: 'A hearty steak sandwich with the comfort of a counter-made favorite.',
	porkroll: 'A breakfast-and-lunch staple made for loyal regulars.',
	hamEggCheese: 'Warm, satisfying, and ready for the morning rush.',
	medianoche: 'A sweet-savory classic that keeps the deli counter feeling personal.',
};
---

<section class="section section--cream products" id="products">
	<div class="container">
		<div class="products__heading">
			<div>
				<p class="eyebrow" data-i18n="products.eyebrow">Featured favorites</p>
				<h2 data-i18n="products.title">Deli counter comfort with grocery convenience.</h2>
			</div>
			<p class="lead" data-i18n="products.copy">
				Real deli favorites, photographed close and kept simple: breakfast plates,
				Uruguayan sandwiches, Cuban classics, and quick pickup comfort.
			</p>
		</div>

		<div class="products__feature">
			<img src="/images/FEATUREDSANDchivito.avif" alt="Chivito sandwich with fries" loading="lazy" />
			<div>
				<p class="eyebrow" data-i18n="products.featureEyebrow">Breakfast to lunch</p>
				<h3 data-i18n="products.featureTitle">The kind of food people build routines around.</h3>
				<p data-i18n="products.featureCopy">
					Start with eggs and coffee, come back for a pressed sandwich, and leave with something
					for home. That is the neighborhood deli rhythm.
				</p>
				<a class="btn btn--primary" data-i18n="products.featureCta" href="#order">Order a favorite</a>
			</div>
		</div>

		<div class="menu-groups">
			<div class="menu-group">
				<div class="menu-group__heading">
					<p class="eyebrow" data-i18n="products.breakfastEyebrow">Breakfast Favorites</p>
					<h3 data-i18n="products.breakfastTitle">Hot starts for the morning crowd.</h3>
				</div>
				<div class="products__grid" aria-label="Breakfast favorites">
					{breakfastFavorites.map((product) => (
						<article class="product-card">
							<img src={product.image} alt={product.alt} loading="lazy" />
							<div class="product-card__content">
								<h4 data-i18n={`products.${product.key}.title`}>{itemLabels[product.key]}</h4>
								<p data-i18n={`products.${product.key}.copy`}>{itemDescriptions[product.key]}</p>
							</div>
						</article>
					))}
				</div>
			</div>

			<div class="menu-group">
				<div class="menu-group__heading">
					<p class="eyebrow" data-i18n="products.sandwichEyebrow">Signature Sandwiches</p>
					<h3 data-i18n="products.sandwichTitle">Pressed, stacked, and made to order.</h3>
				</div>
				<div class="products__grid products__grid--sandwiches" aria-label="Signature sandwiches">
					{signatureSandwiches.map((product) => (
						<article class="product-card">
							<img src={product.image} alt={product.alt} loading="lazy" />
							<div class="product-card__content">
								<h4 data-i18n={`products.${product.key}.title`}>{itemLabels[product.key]}</h4>
								<p data-i18n={`products.${product.key}.copy`}>{itemDescriptions[product.key]}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.products__heading {
		display: grid;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.products__heading .lead {
		max-width: 560px;
	}

	.products__feature {
		display: grid;
		gap: 1.15rem;
		margin-bottom: 2.4rem;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--blue-deep);
		color: var(--white);
		box-shadow: var(--shadow);
	}

	.products__feature img {
		width: 100%;
		aspect-ratio: 16 / 11;
		object-fit: cover;
		object-position: center;
	}

	.products__feature > div {
		display: grid;
		justify-items: start;
		padding: 0 1.2rem 1.25rem;
	}

	.products__feature h3,
	.menu-group__heading h3 {
		font-family: Georgia, "Times New Roman", serif;
		line-height: 1.05;
	}

	.products__feature h3 {
		max-width: 620px;
		margin-bottom: 0.65rem;
		font-size: clamp(1.75rem, 6vw, 3rem);
	}

	.products__feature p:not(.eyebrow) {
		max-width: 590px;
		color: rgba(255, 253, 248, 0.78);
		font-weight: 650;
	}

	.menu-groups,
	.menu-group {
		display: grid;
		gap: 1.65rem;
	}

	.menu-groups {
		gap: 2.7rem;
	}

	.menu-group__heading h3 {
		max-width: 620px;
		margin-bottom: 0;
		font-size: clamp(1.7rem, 5vw, 2.65rem);
	}

	.products__grid {
		display: grid;
		gap: 1.25rem;
	}

	.product-card {
		overflow: hidden;
		border: 1px solid rgba(7, 55, 99, 0.08);
		border-radius: var(--radius);
		background: var(--white);
		box-shadow: var(--shadow-soft);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.product-card:hover {
		transform: translateY(-4px);
		border-color: rgba(245, 184, 46, 0.48);
		box-shadow: var(--shadow);
	}

	.product-card img {
		width: 100%;
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: 50% 48%;
		transition: transform 260ms ease;
	}

	.product-card:hover img {
		transform: scale(1.035);
	}

	.product-card__content {
		min-height: 154px;
		padding: 1.15rem;
	}

	.product-card h4 {
		margin: 0 0 0.5rem;
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.42rem;
		line-height: 1.1;
	}

	.product-card p {
		margin-bottom: 0;
		color: var(--ink-soft);
	}

	@media (min-width: 760px) {
		.products__heading {
			grid-template-columns: minmax(0, 1fr) minmax(320px, 0.5fr);
			align-items: end;
			gap: 2rem;
		}

		.products__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 900px) {
		.products__feature {
			grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.72fr);
			align-items: center;
		}

		.products__feature img {
			height: 100%;
			aspect-ratio: auto;
		}

		.products__feature > div {
			padding: 2rem 2rem 2rem 0;
		}
	}

	@media (min-width: 1040px) {
		.products__grid--sandwiches {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
