---
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import HoursSection from '../components/HoursSection.astro';
import Layout from '../layouts/Layout.astro';
import LocationsSection from '../components/LocationsSection.astro';
import OrderSection from '../components/OrderSection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import SiteNav from '../components/SiteNav.astro';
import StorySection from '../components/StorySection.astro';
---

<Layout
	title="New Jersey Grocery & Deli | Oakland Park & Margate"
	description="A modern bilingual homepage for New Jersey Grocery & Deli, a family-owned Uruguayan deli serving Oakland Park and Margate, Florida."
>
	<SiteNav />
	<main>
		<Hero />
		<StorySection />
		<LocationsSection />
		<HoursSection />
		<ProductsSection />
		<OrderSection />
		<ContactSection />
	</main>
</Layout>

