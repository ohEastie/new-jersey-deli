	const navPanel = document.querySelector('.nav-panel');
	const menuToggle = document.querySelector('.menu-toggle');
	const langButtons = document.querySelectorAll('[data-lang-option]');

	function setMenu(open) {
		navPanel?.classList.toggle('is-open', open);
		menuToggle?.setAttribute('aria-expanded', String(open));
		document.body.classList.toggle('no-scroll', open);
	}

	function setLanguage(lang) {
		const dictionary = translations[lang] || translations.en;
		document.documentElement.lang = lang;
		localStorage.setItem('preferredLanguage', lang);
		document.body.classList.add('is-translating');

		document.querySelectorAll('[data-i18n]').forEach((element) => {
			const key = element.getAttribute('data-i18n');
			if (key && dictionary[key]) {
				element.textContent = dictionary[key];
			}
		});

		langButtons.forEach((button) => {
			const isActive = button.getAttribute('data-lang-option') === lang;
			button.classList.toggle('is-active', isActive);
			button.setAttribute('aria-pressed', String(isActive));
		});

		window.setTimeout(() => document.body.classList.remove('is-translating'), 140);
	}

	menuToggle?.addEventListener('click', () => {
		setMenu(!navPanel?.classList.contains('is-open'));
	});

	document.querySelectorAll('.nav-panel a').forEach((link) => {
		link.addEventListener('click', () => setMenu(false));
	});

	langButtons.forEach((button) => {
		button.addEventListener('click', () => {
			setLanguage(button.getAttribute('data-lang-option') || 'en');
		});
	});

	setLanguage(localStorage.getItem('preferredLanguage') || 'en');
</script>
